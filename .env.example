# Server (Render sets PORT automatically)
NODE_ENV=development
PORT=3000
APP_NAME=pademe-backend

# Comma-separated origins for mobile/web clients (optional locally)
# CORS_ORIGINS=http://localhost:3000,https://your-app.onrender.com

# Supabase → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase → Storage → create a bucket named "uploads" (or change below)
SUPABASE_STORAGE_BUCKET=uploads

# Supabase → Project Settings → Database → Connection string (URI)
# Use "Transaction" pooler (port 6543) for server apps
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_SSL=true
