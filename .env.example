# Server (Render sets PORT automatically)
NODE_ENV=development
PORT=3000
APP_NAME=pademe-backend

# Comma-separated origins for mobile/web clients (optional locally)
# CORS_ORIGINS=http://localhost:3000,https://your-app.onrender.com

# Supabase → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase → Storage → create a bucket named "uploads" (or change below)
SUPABASE_STORAGE_BUCKET=uploads

# Supabase → Project Settings → Database → Connection string (URI)
# Use "Transaction" pooler (port 6543) for server apps
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_SSL=true

# Stripe → Developers → API keys (test mode while building)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_RETURN_URL=http://localhost:3000/stripe/onboarding/complete
STRIPE_CONNECT_REFRESH_URL=http://localhost:3000/stripe/onboarding/refresh
# Deep links opened after Stripe redirects to the URLs above (must match app scheme in app.json)
STRIPE_CONNECT_APP_RETURN_URL=padememobile://stripe-onboarding?return=complete
STRIPE_CONNECT_APP_REFRESH_URL=padememobile://stripe-onboarding?return=refresh
